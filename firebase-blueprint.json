{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "description": "Email address of the user" },
        "name": { "type": "string", "description": "Full name of the user" },
        "photoURL": { "type": "string", "description": "Optional profile picture URL" },
        "role": { "type": "string", "enum": ["admin", "team", "client"], "description": "Access privilege role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of creation" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp of last modification" }
      },
      "required": ["uid", "email", "name", "role", "createdAt", "updatedAt"]
    },
    "Task": {
      "title": "Company Task",
      "description": "A software task assigned to a team member",
      "type": "object",
      "properties": {
        "taskId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedTo": { "type": "string", "description": "UID of the assigned team member" },
        "assignedToName": { "type": "string", "description": "Name of the assigned team member" },
        "assignedByName": { "type": "string", "description": "Name of the admin who created it" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "completed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["taskId", "title", "description", "assignedTo", "assignedToName", "assignedByName", "status", "priority", "createdAt", "updatedAt"]
    },
    "Announcement": {
      "title": "Company Announcement",
      "description": "Global company broadcast updates",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdByName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "createdBy", "createdByName", "createdAt"]
    },
    "Inquiry": {
      "title": "Inquiry Submission",
      "description": "Contact form inquiry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "replied", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "subject", "message", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles keyed by user Auth UID"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Assigned tasks for general team operations"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Company announcements"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Contact form details and metadata"
    }
  }
}
