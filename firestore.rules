rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "babaraliarain2211@gmail.com" ||
        getUserData().role == "admin"
      );
    }

    function isTeam() {
      return isSignedIn() && (
        request.auth.token.email == "babaraliarain2211@gmail.com" ||
        getUserData().role == "team" ||
        getUserData().role == "admin"
      );
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Users Collection
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isTeam());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // 3. Tasks Collection
    match /tasks/{taskId} {
      allow read: if isSignedIn() && (isTeam() || resource.data.assignedTo == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isTeam() && resource.data.assignedTo == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']))
      );
      allow delete: if isAdmin();
    }

    // 4. Announcements Collection
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // 5. Inquiries Collection
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // 6. Projects (Portfolio) Collection
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 7. Services Collection
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 8. Clients Collection
    match /clients/{clientId} {
      allow read, write: if isAdmin();
    }

    // 9. Blogs Collection
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 10. Testimonials Collection
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // 11. Meetings Collection
    match /meetings/{meetingId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // 12. CMS Content Collection
    match /cms/{cmsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 13. Settings Collection
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 14. Logs Collection
    match /logs/{logId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
  }
}
